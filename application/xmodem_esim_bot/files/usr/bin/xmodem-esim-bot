#!/usr/bin/ucode
'use strict';
import * as fs from 'fs';

const APP_NAME = "xmodem-esim-bot";
const APP_VER = "2.0.0";
const STATE_DIR = "/tmp/lpac-esim";
const OFFSET_FILE = `${STATE_DIR}/telegram.offset`;
const STATUS_FILE = `${STATE_DIR}/telegram.status`;
const PENDING_FILE = `${STATE_DIR}/telegram.pending`;
const PID_FILE = "/var/run/xmodem-esim-bot.pid";

let config = {
	enabled: false,
	token: "",
	chat_id: "",
	poll_interval: 0,
	allow_disruptive: true,
	require_confirm: true,
	debug: false
};
let tg_api = "";
let last_update_id = 0;

function sys(cmd) { let f = fs.popen(cmd, "r"); if (!f) return ""; let out = f.read("all"); f.close(); return out || ""; }
function sys_bg(cmd) { system(`${cmd} >/dev/null 2>&1 &`); }
function sys_exec(cmd) { system(`${cmd} >/dev/null 2>&1`); }
function trim(s) { return replace(replace(`${s || ""}`, /^\s+/, ""), /\s+$/, ""); }
function sh_quote(s) { return "'" + replace(`${s || ""}`, "'", "'\\''") + "'"; }
function html(s) { s = `${s || ""}`; s = replace(s, "&", "&amp;"); s = replace(s, "<", "&lt;"); s = replace(s, ">", "&gt;"); return s; }
function is_lpa(s) { return match(`${s || ""}`, /^[Ll][Pp][Aa]:1\$/); }
function safe_int(v, def) { let n = int(v); return n == null ? def : n; }

function log(msg) { sys_exec(`logger -t ${sh_quote(APP_NAME)} ${sh_quote(msg)}`); }
function log_debug(msg) { if (config.debug) log(`[D] ${msg}`); }
function ensure_state_dir() { sys_exec(`mkdir -p ${sh_quote(STATE_DIR)}`); }
function current_pid() { return trim(sys(`pgrep -f '^/usr/bin/ucode /usr/bin/xmodem-esim-bot$' | head -n1`)) || trim(sys(`pgrep -f '/usr/bin/xmodem-esim-bot' | head -n1`)) || "0"; }
function write_status(state, rc) {
	ensure_state_dir();
	let f = fs.open(STATUS_FILE, "w");
	if (f) { f.write(sprintf('%J\n', {state: state, last_poll: time(), last_rc: rc || 0, pid: current_pid()})); f.close(); }
}
function load_offset() { let off = trim(fs.readfile(OFFSET_FILE)); if (off) last_update_id = safe_int(off, 0); }
function save_offset() { ensure_state_dir(); let f = fs.open(OFFSET_FILE, "w"); if (f) { f.write(`${last_update_id}`); f.close(); } }
function set_pending(action, arg) { ensure_state_dir(); let f = fs.open(PENDING_FILE, "w"); if (f) { f.write(sprintf("%J", {action: action, arg: arg || ""})); f.close(); } }
function get_pending() { try { let raw = fs.readfile(PENDING_FILE); return raw ? json(raw) : null; } catch (e) { return null; } }
function clear_pending() { sys_exec(`rm -f ${sh_quote(PENDING_FILE)}`); }

function uci_get(path, def) { let v = trim(sys(`uci -q get ${sh_quote(path)} 2>/dev/null`)); return v || def || ""; }
function uci_set(path, value) { sys_exec(`uci -q set ${sh_quote(`${path}=${value}`)}`); }
function load_config() {
	let r = sys("ubus call uci get '{\"config\":\"xmodem_esim_bot\",\"section\":\"main\"}' 2>/dev/null");
	let d = null; try { d = json(r); } catch (e) {}
	if (!d || !d.values) return false;
	let v = d.values;
	let get = function(k, def) { return exists(v, k) ? v[k] : def; };
	config.enabled = (get("enabled", "0") == "1");
	config.token = get("token", "");
	config.chat_id = `${get("chat_id", "")}`;
	config.poll_interval = safe_int(get("poll_interval", "1"), 1);
	config.allow_disruptive = (get("allow_disruptive", "1") == "1");
	config.require_confirm = (get("require_confirm", "1") == "1");
	config.debug = (get("debug", "0") == "1");
	if (!config.token || !config.enabled) return false;
	tg_api = `https://api.telegram.org/bot${config.token}`;
	return true;
}

function lpac_api(method, args) {
	let cmd = `ubus call lpac_esim ${method}`;
	if (args) cmd += ` ${sh_quote(sprintf("%J", args))}`;
	try {
		let res = json(sys(`${cmd} 2>/dev/null`));
		if (res && res.payload && exists(res.payload, "data")) return {success: (res.payload.code === 0), data: res.payload.data, msg: res.payload.message || ""};
		return res || {success: false, error: "Empty response"};
	} catch (e) { return {success: false, error: "Invalid JSON from ubus"}; }
}
function tg_post(method, payload) {
	let t = `/tmp/xmodem-esim-bot-${time()}-${method}.json`;
	let f = fs.open(t, "w");
	if (!f) return null;
	f.write(sprintf("%J", payload));
	f.close();
	let r = sys(`curl -s -m 20 -X POST -H "Content-Type: application/json" -d @${sh_quote(t)} ${sh_quote(`${tg_api}/${method}`)}`);
	fs.unlink(t);
	try { return json(r); } catch (e) { log_debug(`Telegram ${method} invalid response: ${r}`); return null; }
}
function tg_send(text, markup) { let p = {chat_id: config.chat_id, text: text, parse_mode: "HTML"}; if (markup) p.reply_markup = markup; return tg_post("sendMessage", p); }
function tg_edit(id, text, markup) { if (!id) return tg_send(text, markup); let p = {chat_id: config.chat_id, message_id: id, text: text, parse_mode: "HTML"}; if (markup) p.reply_markup = markup; return tg_post("editMessageText", p); }
function tg_answer(cb, text) { if (!cb) return null; let p = {callback_query_id: cb}; if (text) p.text = text; return tg_post("answerCallbackQuery", p); }
function tg_send_retry(text, inline_keyboard) {
	let markup = inline_keyboard ? {inline_keyboard: inline_keyboard} : null;
	for (let i = 0; i < 18; i++) {
		let r = tg_send(text, markup);
		if (r && r.ok) return true;
		sys_exec("sleep 5");
	}
	log("tg_send_retry failed after 18 attempts");
	return false;
}
function update_ui(msg_id, text, markup) { let r = msg_id ? tg_edit(msg_id, text, markup) : tg_send(text, markup); return (r && r.ok && r.result && r.result.message_id) ? r.result.message_id : msg_id; }

const INLINE_MENU = [[{text: "🏠 Menu", callback_data: "menu:main"}]];
function send_main_menu() {
	clear_pending();
	tg_send(`<b>XModem eSIM Bot v${APP_VER}</b>\n\nSelect a menu below or type a command.`, {
		keyboard: [[{text: "📱 Info EID"}, {text: "📋 Profile List"}], [{text: "📥 Download eSIM"}, {text: "🔔 Notifications"}], [{text: "📡 Modem Status"}, {text: "⚙️ Settings"}], [{text: "❓ Help"}]],
		resize_keyboard: true
	});
}
function ui_help() {
	tg_send(`📋 <b>XModem eSIM Bot v${APP_VER}</b>\n\n<b>Menu Buttons:</b>\n📱 Info EID — eUICC chip info, storage, EID\n📋 Profile List — switch/manage eSIM profiles\n📥 Download — download new eSIM profile\n🔔 Notifications — process pending notifications\n📡 Modem Status — signal, operator, band, temperature\n⚙️ Settings — toggle backend/proxy/debug\n\n<b>Commands:</b>\n/eid — Full eUICC chip information\n/profiles — Profile list with switch buttons\n/status — Modem status &amp; signal details\n/download &lt;LPA&gt; — Download new profile\n/enable &lt;ICCID&gt; — Switch to another profile\n/delete &lt;ICCID&gt; — Delete profile (permanent)\n/notif — Process eSIM notifications\n/settings — lpac backend settings\n/chatid — Show your Chat ID\n\n<b>Manage (via buttons):</b>\n⚡ Manage Profile — delete/rename profiles\n🔄 SIM Switch — switch between SIM card and eSIM\n✏️ Rename — change profile nickname`);
}
function ui_help_short() {
	tg_send(`📋 <b>Commands</b>\n\n/eid - eUICC chip info\n/profiles - Profile list with buttons\n/status - Modem status &amp; signal\n/download &lt;LPA&gt; - Download profile\n/enable &lt;ICCID&gt; - Switch profile\n/delete &lt;ICCID&gt; - Delete profile\n/notif - Process notifications\n/settings - Backend settings\n/chatid - Show Chat ID\n/cancel - Cancel current operation`);
}

function get_modem_section() { return trim(sys(`uci show xmodem 2>/dev/null | grep '=modem-device' | head -n1 | cut -d. -f2 | cut -d= -f1`)); }
function modem_get(section, key, def) { return section ? uci_get(`xmodem.${section}.${key}`, def) : (def || ""); }
function ubus_xmodem(method, section) { try { return json(sys(`ubus call xmodem ${method} ${sh_quote(sprintf("%J", {config_section: section}))} 2>/dev/null`)); } catch (e) { return null; } }
function info_value(obj, keys, def) {
	if (!obj) return def || "";
	if (type(keys) != "array") keys = [keys];
	for (let i = 0; i < length(keys); i++) if (exists(obj, keys[i]) && obj[keys[i]]) return obj[keys[i]];
	let list = obj.modem_info || [];
	for (let i = 0; i < length(list); i++) {
		for (let j = 0; j < length(keys); j++) {
			let k = `${keys[j]}`;
			if (`${list[i].key || ""}` == k || `${list[i].full_name || ""}` == k) return `${list[i].value || ""}`;
		}
	}
	return def || "";
}
function btn_label(s, max) { s = `${s || ""}`; max = max || 32; return length(s) > max ? `${substr(s, 0, max - 1)}…` : s; }
function esim_ctrl_result(raw) {
	let d = null; try { d = json(raw); } catch (e) {}
	if (d && d.result) return {ok: `${d.result.status || ""}` == "1", error: d.result.error || d.result.message || raw};
	if (d && exists(d, "success")) return {ok: d.success === true, error: d.error || d.message || raw};
	return {ok: match(raw || "", /success/i), error: raw || "Unknown error"};
}
function find_profile(iccid) {
	let r = lpac_api("profiles");
	if (!r.success || !r.data) return null;
	for (let i = 0; i < length(r.data); i++) if (`${r.data[i].iccid || ""}` == `${iccid || ""}`) return r.data[i];
	return null;
}
function at_cmd(port, cmd) { if (!port) return ""; return trim(sys(`sms_tool_q -d ${sh_quote(port)} at ${sh_quote(cmd)} 2>/dev/null | tr -d '\r'`)); }
function get_current_slot(section) {
	let at_port = modem_get(section, "at_port", "");
	let manufacturer = modem_get(section, "manufacturer", "");
	let cur = "";
	if (at_port) {
		let r = "";
		if (match(manufacturer, /[Ff]oxconn/)) {
			r = at_cmd(at_port, "AT^SWITCH_SLOT?");
			if (match(r, /SIM1/i)) cur = "0"; else if (match(r, /SIM2/i)) cur = "1";
		} else if (match(manufacturer, /[Qq]uectel/)) {
			r = at_cmd(at_port, "AT+QUIMSLOT?");
			let m = match(r, /\+QUIMSLOT:\s*([0-9]+)/); if (m) cur = m[1];
		}
		if (!cur) {
			r = at_cmd(at_port, "AT^SWITCH_SLOT?");
			let m = match(r, /SWITCH_SLOT[^0-9]*([0-9]+)/i); if (m) cur = m[1];
			if (!cur) { r = at_cmd(at_port, "AT+QUIMSLOT?"); m = match(r, /\+QUIMSLOT:\s*([0-9]+)/); if (m) cur = m[1]; }
		}
	}
	return cur || modem_get(section, "sim_slot", "");
}

function ui_eid(msg_id) {
	msg_id = update_ui(msg_id, "⏳");
	let chip = lpac_api("chip");
	let profiles = lpac_api("profiles");
	if (!chip.success) return update_ui(msg_id, `❌ <b>Gagal membaca EID</b>\n${html(chip.error || chip.msg || "Unknown error")}`, {inline_keyboard: INLINE_MENU});
	let d = chip.data || {};
	let info = d.EUICCInfo2 || {};
	let res = info.extCardResource || {};
	let addr = d.EuiccConfiguredAddresses || {};
	let free_nv = res.freeNonVolatileMemory || "-";
	let nv_display = `${free_nv} B`;
	if (free_nv != "-" && safe_int(free_nv, 0) > 1024) nv_display = `${int(free_nv / 1024)} KB`;
	let count = profiles.success && profiles.data ? length(profiles.data) : 0;
	let section = get_modem_section();
	let slot = get_current_slot(section);
	let slot_text = slot ? `SIM Slot: ${slot}` : "SIM Switch";
	let text = `📱 <b>eUICC / eSIM Chip Info</b>\n\n🔑 <b>EID:</b>\n<code>${html(d.eidValue || "-")}</code>\n\n📊 <b>Chip Info:</b>\n  • SVN: <code>${html(info.svn || "-")}</code>\n  • Firmware: <code>${html(info.euiccFirmwareVer || "-")}</code>\n  • SM-DP+: <code>${html(addr.defaultDpAddress || "Not set")}</code>\n  • SM-DS: <code>${html(addr.rootDsAddress || "-")}</code>\n\n💾 <b>Storage:</b>\n  • Free NV: ${html(nv_display)}\n  • Free RAM: ${html(res.freeVolatileMemory || "-")} B\n  • Apps: ${html(res.installedApplication || "0")}\n\n📂 <b>Profiles:</b> ${count} stored`;
	update_ui(msg_id, text, {inline_keyboard: [[{text: "📋 Profiles", callback_data: "menu:profiles", style: "primary"}, {text: `🔄 ${slot_text}`, callback_data: "menu:simswitch", style: "primary"}], [{text: "🏠 Menu", callback_data: "menu:main"}]]});
}

function profile_name(p) { return p.profileNickname || p.profileName || p.serviceProviderName || "Unknown"; }
function profile_active(p) { return p.profileState == "enabled" || p.state == "enabled"; }
function profile_delete_confirm_text(iccid) {
	let p = find_profile(iccid);
	if (!p) return `🗑 <b>Delete Profile?</b>\n\n<b>ICCID:</b> <code>${html(iccid)}</code>\n\nProfile akan dihapus permanen.`;

	let nickname = p.profileNickname || "-";
	let name = p.profileName || "-";
	let provider = p.serviceProviderName || p.serviceProvider || "-";
	let state = p.profileState || p.state || "-";

	return `🗑 <b>Delete Profile?</b>\n\n<b>Nickname:</b> ${html(nickname)}\n<b>Profile:</b> ${html(name)}\n<b>Provider:</b> ${html(provider)}\n<b>ICCID:</b> <code>${html(iccid)}</code>\n<b>Status:</b> ${html(state)}\n\nProfile akan dihapus permanen.`;
}
function ui_profiles(msg_id) {
	msg_id = update_ui(msg_id, "⏳");
	let res = lpac_api("profiles");
	if (!res.success) return update_ui(msg_id, `❌ <b>Gagal membaca profiles</b>\n${html(res.error || res.msg || "Unknown error")}`, {inline_keyboard: INLINE_MENU});
	let p = res.data || [];
	if (length(p) == 0) return update_ui(msg_id, "📋 No profiles.", {inline_keyboard: [[{text: "📥 Download eSIM", callback_data: "menu:download", style: "success"}], [{text: "🏠 Menu", callback_data: "menu:main"}]]});
	let text = `📋 <b>Profiles</b> (${length(p)})`;
	let active_rows = [], inactive_buttons = [];
	for (let i = 0; i < length(p); i++) {
		let n = profile_name(p[i]);
		let iccid = `${p[i].iccid || ""}`;
		let active = profile_active(p[i]);
		if (active) active_rows[length(active_rows)] = [{text: `Aktif • ${btn_label(n)} 🔒`, callback_data: "noop", style: "primary"}];
		else inactive_buttons[length(inactive_buttons)] = {text: btn_label(n), callback_data: `sw:${iccid}`, style: "danger"};
	}
	let kb = [];
	for (let i = 0; i < length(active_rows); i++) kb[length(kb)] = active_rows[i];
	for (let i = 0; i < length(inactive_buttons); i += 2) {
		let row = [inactive_buttons[i]];
		if (inactive_buttons[i + 1]) row[1] = inactive_buttons[i + 1];
		kb[length(kb)] = row;
	}
	kb[length(kb)] = [{text: "⚡ Manage Profile", callback_data: "menu:manage", style: "primary"}];
	kb[length(kb)] = [{text: "📥 Download eSIM", callback_data: "menu:download", style: "success"}];
	kb[length(kb)] = [{text: "🔔 Notif", callback_data: "act:notifprocess"}, {text: "🏠 Menu", callback_data: "menu:main"}];
	update_ui(msg_id, text, {inline_keyboard: kb});
}

function ui_manage(msg_id) {
	msg_id = update_ui(msg_id, "⏳");
	let res = lpac_api("profiles");
	if (!res.success) return update_ui(msg_id, `❌ <b>Gagal</b>\n${html(res.error || res.msg || "Unknown error")}`, {inline_keyboard: INLINE_MENU});
	let p = res.data || [], kb = [], del_buttons = [];
	let text = "⚡ <b>Manage Profile</b>\n\nPilih profile nonaktif untuk delete. Profile aktif sengaja dikunci agar tidak terhapus.\n\n";
	for (let i = 0; i < length(p); i++) {
		let n = profile_name(p[i]), iccid = `${p[i].iccid || ""}`;
		if (profile_active(p[i])) {
			text += `🔒 <b>${html(n)}</b> (active)\n`;
			kb[length(kb)] = [{text: `🔒 ${btn_label(n)}`, callback_data: "noop", style: "primary"}];
		} else {
			text += `🗑 ${html(n)}\n`;
			del_buttons[length(del_buttons)] = {text: `🗑 ${btn_label(n)}`, callback_data: `del:${iccid}`, style: "danger"};
		}
	}
	for (let i = 0; i < length(del_buttons); i += 2) {
		let row = [del_buttons[i]];
		if (del_buttons[i + 1]) row[1] = del_buttons[i + 1];
		kb[length(kb)] = row;
	}
	kb[length(kb)] = [{text: "✏️ Rename Profile", callback_data: "menu:rename", style: "primary"}];
	kb[length(kb)] = [{text: "📋 Profiles", callback_data: "menu:profiles"}, {text: "🏠 Menu", callback_data: "menu:main"}];
	update_ui(msg_id, text, {inline_keyboard: kb});
}

function ui_rename_menu(msg_id) {
	msg_id = update_ui(msg_id, "⏳");
	let res = lpac_api("profiles");
	if (!res.success) return update_ui(msg_id, `❌ <b>Gagal</b>\n${html(res.error || res.msg || "Unknown error")}`, {inline_keyboard: INLINE_MENU});
	let p = res.data || [], kb = [], buttons = [];
	for (let i = 0; i < length(p); i++) buttons[length(buttons)] = {text: `✏️ ${btn_label(profile_name(p[i]))}`, callback_data: `ren:${p[i].iccid}`, style: "primary"};
	for (let i = 0; i < length(buttons); i += 2) {
		let row = [buttons[i]];
		if (buttons[i + 1]) row[1] = buttons[i + 1];
		kb[length(kb)] = row;
	}
	kb[length(kb)] = [{text: "⚡ Manage", callback_data: "menu:manage"}, {text: "🏠 Menu", callback_data: "menu:main"}];
	update_ui(msg_id, "✏️ <b>Rename Profile</b>\n\nSelect profile to rename:", {inline_keyboard: kb});
}

function ui_download_prompt(msg_id) {
	clear_pending(); set_pending("download", "");
	update_ui(msg_id, "📥 <b>Download eSIM</b>

Send activation code in format:
<code>LPA:1$smdp.example.com$MATCHING-ID</code>

Or tap Cancel.", {inline_keyboard: [[{text: "❌ Cancel", callback_data: "cancel"}]]});
}

function ui_notif(msg_id) {
	msg_id = update_ui(msg_id, "⏳");
	let r = lpac_api("notif_list");
	if (!r.success) return update_ui(msg_id, "❌ Failed to read notifications.", {inline_keyboard: INLINE_MENU});
	let list = r.data || [];
	update_ui(msg_id, `🔔 Pending: ${length(list)}`, {inline_keyboard: [[{text: "⚡ Process All", callback_data: "act:notifprocess"}, {text: "🏠 Menu", callback_data: "menu:main"}]]});
}

function signal_bar(percent) { percent = safe_int(percent, 0); if (percent >= 80) return "▰▰▰▰▰"; if (percent >= 60) return "▰▰▰▰▱"; if (percent >= 40) return "▰▰▰▱▱"; if (percent >= 20) return "▰▰▱▱▱"; if (percent > 0) return "▰▱▱▱▱"; return "▱▱▱▱▱"; }
function legacy_signal_bar(percent) { percent = safe_int(percent, -1); if (percent >= 80) return "▁▃▅▇█"; if (percent >= 60) return "▁▃▅▇░"; if (percent >= 40) return "▁▃▅░░"; if (percent >= 20) return "▁▃░░░"; if (percent >= 0) return "▁░░░░"; return "░░░░░"; }
function reg_text(cereg) {
	let m = match(cereg || "", /\+CEREG:\s*[0-9]+,\s*([0-9]+)/);
	if (!m) return cereg || "-";
	let v = `${m[1]}`;
	if (v == "1") return "Registered (home)";
	if (v == "5") return "Registered (roaming)";
	if (v == "2") return "Searching";
	if (v == "3") return "Denied";
	if (v == "0") return "Not registered";
	return `State ${v}`;
}
function parse_debug(debug) {
	let out = {rsrp: "-", rsrq: "-", rssi: "-", sinr: "-", band: "-", nr_band: "-", pci: "-", earfcn: "-"};
	if (!debug) return out;
	let m;
	m = match(debug, /RSRP[^-0-9]*(-?[0-9]+)/i); if (m) out.rsrp = `${m[1]} dBm`;
	m = match(debug, /RSRQ[^-0-9]*(-?[0-9]+)/i); if (m) out.rsrq = `${m[1]} dB`;
	m = match(debug, /RSSI[^-0-9]*(-?[0-9]+)/i); if (m) out.rssi = `${m[1]} dBm`;
	m = match(debug, /SINR[^-0-9]*(-?[0-9]+)/i); if (m) out.sinr = `${m[1]} dB`;
	m = match(debug, /LTE\s*Band[^0-9]*([Bb]?[0-9]+)/i); if (!m) m = match(debug, /Band[^0-9]*([Bb]?[0-9]+)/i); if (m) out.band = `${m[1]}`;
	m = match(debug, /NR[^0-9]*Band[^0-9]*([Nn]?[0-9]+)/i); if (m) out.nr_band = `${m[1]}`;
	m = match(debug, /PCI[^0-9]*([0-9]+)/i); if (m) out.pci = `${m[1]}`;
	m = match(debug, /EARFCN[^0-9]*([0-9]+)/i); if (m) out.earfcn = `${m[1]}`;
	return out;
}
function ui_modem(msg_id) {
	msg_id = update_ui(msg_id, "⏳");
	let section = get_modem_section();
	let at_port = section ? modem_get(section, "at_port", "") : "";
	let manufacturer = section ? modem_get(section, "manufacturer", "") : "";
	if (!at_port || system(`test -e ${sh_quote(at_port)}`) != 0 || system("test -x /usr/bin/sms_tool_q") != 0)
		return update_ui(msg_id, "❌ AT port not available.", {inline_keyboard: INLINE_MENU});

	let bi = ubus_xmodem("base_info", section) || {};
	let ni = ubus_xmodem("network_info", section) || {};
	let ci = ubus_xmodem("cell_info", section) || {};
	let model = "-", fw = "-", imei = "-", op = "-", tech = "-", state = "-";
	let sig_pct = "-", sig_dbm = "-", temp = "-";
	let rsrp = "-", rsrq = "-", rssi = "-", sinr = "-";
	let pband = "-", pci = "-", earfcn = "-", ca_bands = "";

	let mfr = info_value(bi, "manufacturer", "");
	let mdl = info_value(bi, "name", "");
	if (!mfr && !mdl) {
		mfr = trim(sys(`sms_tool_q -d ${sh_quote(at_port)} at 'AT+CGMI' 2>/dev/null | grep -v '^AT\|^OK\|^$' | head -1 | sed 's/^+CGMI: *//;s/"//g' | tr -d '\r'`));
		mdl = trim(sys(`sms_tool_q -d ${sh_quote(at_port)} at 'AT+CGMM' 2>/dev/null | grep -v '^AT\|^OK\|^$' | head -1 | sed 's/^+CGMM: *//;s/"//g;s/,.*//' | tr -d '\r'`));
	}
	model = trim(`${mfr} ${mdl}`) || "-";
	fw = info_value(bi, "revision", "");
	if (!fw) fw = trim(sys(`sms_tool_q -d ${sh_quote(at_port)} at 'AT+CGMR' 2>/dev/null | grep -v '^AT\|^OK\|^$' | head -1 | sed 's/^+CGMR: *//;s/"//g' | tr -d '\r'`));
	fw = fw || "-";

	let resp = at_cmd(at_port, "AT+CGSN");
	let m = match(resp, /([0-9]{15})/); if (m) imei = m[1];

	resp = at_cmd(at_port, "AT+COPS?");
	if (match(resp, /\+COPS:/)) {
		m = match(resp, /"([^"]*)"/); if (m) op = m[1];
		if (op == "-") { m = match(resp, /\+COPS:[^,]*,[^,]*,([^,]*)/); if (m) op = replace(m[1], '"', ""); }
		m = match(resp, /,([0-9]+)$/); if (m) {
			let act = `${m[1]}`;
			if (act == "7") tech = "LTE"; else if (act == "12") tech = "NR 5G"; else if (act == "13") tech = "5G NSA"; else if (act == "0") tech = "GSM"; else if (act == "2") tech = "UTRAN"; else if (act == "6") tech = "HSPA+";
		}
	}
	let nt = info_value(ni, "Network Type", ""); if (nt) tech = nt;

	resp = at_cmd(at_port, "AT+CSQ");
	m = match(resp, /\+CSQ:\s*([0-9]+)/); if (m && `${m[1]}` != "99") { let csq = safe_int(m[1], 0); sig_dbm = `${csq * 2 - 113}`; sig_pct = `${csq * 100 / 31}`; if (safe_int(sig_pct, 0) > 100) sig_pct = "100"; }
	resp = at_cmd(at_port, "AT+CEREG?");
	m = match(resp, /\+CEREG:\s*[0-9]+,\s*([0-9]+)/); if (m) { let reg = `${m[1]}`; if (reg == "1") state = "Registered (Home)"; else if (reg == "5") state = "Roaming"; else if (reg == "2") state = "Searching"; else if (reg == "3") state = "Denied"; else if (reg == "0") state = "Not registered"; }

	resp = at_cmd(at_port, "AT^TEMP?");
	if (match(resp, /TSENS|PA|Skin/i)) {
		m = match(resp, /TSENS[^0-9-]*(-?[0-9]+)/); if (m) temp = `${m[1]}°C`;
		let p = match(resp, /PA[^0-9-]*(-?[0-9]+)/); if (p && (!m || safe_int(p[1], -999) > safe_int(m[1], -999))) temp = `${p[1]}°C`;
	}

	let v;
	v = info_value(ci, "Band", ""); if (v) pband = `B${v}`;
	v = info_value(ci, "DL Bandwidth", ""); if (pband != "-" && v) pband = `${pband} @${v}MHz`;
	v = info_value(ci, "Physical Cell ID", ""); if (v) pci = v;
	v = info_value(ci, "EARFCN", ""); if (v) earfcn = v;
	v = info_value(ci, "RSRP", ""); if (v) rsrp = `${v}dBm`;
	v = info_value(ci, "RSRQ", ""); if (v) rsrq = `${v}dB`;
	v = info_value(ci, "RSSI", ""); if (v) rssi = `${v}dBm`;
	v = info_value(ci, "SINR", ""); if (v) sinr = `${v}dB`;
	v = info_value(ci, "NR Band", ""); if (v) ca_bands = `n${v}`;

	if (pband == "-" && rsrp == "-") {
		resp = at_cmd(at_port, "AT^DEBUG?");
		if (match(resp, /pcell|lte_rsrp/i)) {
			if (match(resp, /scell:/)) tech = "LTE-A";
			if (match(resp, /nr_band:/)) tech = "5G NSA";
			let pcell = trim(sys(`printf %s ${sh_quote(resp)} | grep '^pcell:' | head -1`));
			m = match(pcell, /lte_band:([0-9]+)/); if (m) pband = `B${m[1]}`;
			m = match(pcell, /lte_band_width:([0-9.]*MHz)/); if (m) pband = `${pband} @${m[1]}`;
			let chan = trim(sys(`printf %s ${sh_quote(resp)} | grep -A1 '^pcell:' | grep 'channel:' | head -1`));
			m = match(chan, /pci:([0-9]+)/); if (m) pci = m[1];
			m = match(chan, /channel:([0-9]+)/); if (m) earfcn = m[1];
			let rs = trim(sys(`printf %s ${sh_quote(resp)} | grep -A2 '^pcell:' | grep 'lte_rsrp:' | head -1`));
			m = match(rs, /lte_rsrp:([^,]*)/); if (m) rsrp = m[1];
			m = match(rs, /rsrq:([^,]*)/); if (m) rsrq = m[1];
			let ri = trim(sys(`printf %s ${sh_quote(resp)} | grep -A3 '^pcell:' | grep 'lte_rssi:' | head -1`));
			m = match(ri, /lte_rssi:([^,]*)/); if (m) rssi = m[1];
			m = match(ri, /lte_snr:([^,]*)/); if (m) sinr = m[1] == "NA" ? "-" : m[1];
			ca_bands = trim(sys(`printf %s ${sh_quote(resp)} | grep '^scell:' | grep -o 'lte_band:[0-9]*' | cut -d: -f2 | awk '{printf "B%s+", $1}' | sed 's/+$//'`)) || ca_bands;
		}
	}

	let bar = legacy_signal_bar(sig_pct);
	let text = `📡 <b>Modem Status</b>\n\n<b>Signal:</b> ${bar} ${html(sig_pct)}% (${html(sig_dbm)} dBm)\n<b>Operator:</b> ${html(op)}\n<b>Technology:</b> ${html(tech)}\n<b>State:</b> ${html(state)}`;
	if (pband != "-") text += `\n<b>Band:</b> ${html(pband)}`;
	if (ca_bands) text += ` + ${html(ca_bands)}`;
	if (pci != "-" && pci) text += `\n<b>PCI:</b> ${html(pci)} | <b>EARFCN:</b> ${html(earfcn)}`;
	if (rsrp != "-" || rssi != "-") {
		text += "\n\n📶 <b>Signal Detail:</b>";
		if (rsrp != "-") text += `\n  RSRP: <code>${html(rsrp)}</code>`;
		if (rsrq != "-") text += ` | RSRQ: <code>${html(rsrq)}</code>`;
		if (rssi != "-") text += `\n  RSSI: <code>${html(rssi)}</code>`;
		if (sinr != "-") text += ` | SINR: <code>${html(sinr)}</code>`;
	}
	text += `\n\n📋 <b>Modem:</b> <code>${html(model)}</code>`;
	if (fw != "-" && fw) text += `\n<b>FW:</b> <code>${html(fw)}</code>`;
	if (temp != "-") text += ` | <b>Temp:</b> ${html(temp)}`;
	if (imei != "-") text += `\n<b>IMEI:</b> <code>${html(imei)}</code>`;
	update_ui(msg_id, text, {inline_keyboard: [[{text: "🔄 Refresh", callback_data: "act:status"}, {text: "🏠 Menu", callback_data: "menu:main"}]]});
}

function ui_settings(msg_id) {
	let backend = uci_get("lpac-esim.main.apdu_backend", "mbim");
	let proxy = uci_get("lpac-esim.main.mbim_proxy", "1");
	let skip = uci_get("lpac-esim.main.skip_slot_mapping", "1");
	let apdu_debug = uci_get("lpac-esim.main.apdu_debug", "0");
	let proxyText = proxy == "1" ? "ON" : "OFF";
	let skipText = skip == "1" ? "ON" : "OFF";
	let debugText = apdu_debug == "1" ? "ON" : "OFF";
	let text = `⚙️ <b>Settings</b>

<b>Backend:</b> <code>${html(backend)}</code>
<b>MBIM Proxy:</b> ${proxyText}
<b>Skip Slot Mapping:</b> ${skipText}
<b>Debug:</b> ${debugText}`;
	update_ui(msg_id, text, {inline_keyboard: [
		[{text: "Backend QMI", callback_data: "cfg:backend:qmi", style: backend == "qmi" ? "primary" : "danger"}, {text: "Backend MBIM", callback_data: "cfg:backend:mbim", style: backend == "mbim" ? "primary" : "danger"}, {text: "Backend AT", callback_data: "cfg:backend:at", style: backend == "at" ? "primary" : "danger"}],
		[{text: `MBIM Proxy: ${proxyText}`, callback_data: "cfg:toggle:mbim_proxy", style: proxy == "1" ? "primary" : "danger"}, {text: `Skip Slot: ${skipText}`, callback_data: "cfg:toggle:skip_slot_mapping", style: skip == "1" ? "primary" : "danger"}],
		[{text: `Debug: ${debugText}`, callback_data: "cfg:toggle:apdu_debug", style: apdu_debug == "1" ? "primary" : "danger"}],
		[{text: "🏠 Menu", callback_data: "menu:main"}]
	]});
}

function ui_sim_switch(msg_id) {
	let section = get_modem_section();
	if (!section) return update_ui(msg_id, "❌ <b>SIM Switch</b>\nModem section tidak ditemukan.", {inline_keyboard: INLINE_MENU});
	let manufacturer = modem_get(section, "manufacturer", "");
	let slot = get_current_slot(section);
	let text = `🔄 <b>SIM Switch</b>\n\nModem: <code>${html(section)}</code>\nManufacturer: ${html(manufacturer || "-")}\nCurrent slot: <b>${html(slot || "unknown")}</b>\n\nPilih slot tujuan:`;
	let kb;
	if (match(manufacturer, /[Ff]oxconn/)) kb = [[{text: `${slot == "0" ? "✅" : "▫️"} SIM Card`, callback_data: "simslot:0", style: slot == "0" ? "success" : "primary"}, {text: `${slot == "1" ? "✅" : "▫️"} eSIM`, callback_data: "simslot:1", style: slot == "1" ? "success" : "primary"}], [{text: "📱 EID Info", callback_data: "menu:eid"}, {text: "🏠 Menu", callback_data: "menu:main"}]];
	else kb = [[{text: `${slot == "1" ? "✅" : "▫️"} Slot 1`, callback_data: "simslot:1", style: slot == "1" ? "success" : "primary"}, {text: `${slot == "2" ? "✅" : "▫️"} Slot 2`, callback_data: "simslot:2", style: slot == "2" ? "success" : "primary"}], [{text: "📱 EID Info", callback_data: "menu:eid"}, {text: "🏠 Menu", callback_data: "menu:main"}]];
	update_ui(msg_id, text, {inline_keyboard: kb});
}

function poll_lock_result(timeout) {
	let elapsed = 0;
	while (elapsed < timeout) {
		sys_exec("sleep 3"); elapsed += 3;
		let s = lpac_api("lock_status");
		if (s && s.data && s.data.locked === false) return s.data.last_result || {};
	}
	return null;
}
function do_switch(iccid) {
	if (!config.allow_disruptive) return tg_send("⛔ Operasi switch dinonaktifkan.");
	let section = get_modem_section();
	tg_send("⏳");
	let result = section ? sys(`/usr/share/xmodem/esim_ctrl.sh profile_enable ${sh_quote(section)} ${sh_quote(sprintf("%J", {iccid: iccid, refresh: "1"}))} 2>/dev/null`) : '{"result":{"status":"0","error":"no modem section"}}';
	let parsed = esim_ctrl_result(result);
	if (parsed.ok)
		tg_send_retry(`✅ <b>Profile Switched</b>

ICCID: <code>${html(iccid)}</code>
Internet reconnected.`, [[{text: "📋 Profile List", callback_data: "menu:profiles"}], [{text: "🏠 Menu", callback_data: "menu:main"}]]);
	else
		tg_send_retry(`❌ <b>Switch Failed</b>

Error: ${html(parsed.error || "Unknown")}`, [[{text: "📋 Profile List", callback_data: "menu:profiles"}], [{text: "🏠 Menu", callback_data: "menu:main"}]]);
}
function do_delete(iccid) {
	tg_send("⏳");
	let r = lpac_api("delete", {iccid: iccid});
	if (r.success || r.msg == "success")
		tg_send("✅ Profile deleted.", {inline_keyboard: [[{text: "📋 Profile List", callback_data: "menu:profiles"}], [{text: "🏠 Menu", callback_data: "menu:main"}]]});
	else
		tg_send(`❌ Delete failed: ${html(r.error || r.msg || "Unknown")}`, {inline_keyboard: INLINE_MENU});
}
function do_download(lpa) {
	tg_send("⏳");
	let first = lpac_api("download", {lpa: lpa});
	if (!first.success && !match(first.msg || first.error || "", /process|busy|lock|background/i)) {
		let err = first.error || first.msg || "Unknown error";
		return tg_send(`❌ <b>Download Failed</b>

Error: ${html(err)}`, {inline_keyboard: [[{text: "📥 Try Again", callback_data: "menu:download"}], [{text: "🏠 Menu", callback_data: "menu:main"}]]});
	}
	let r = poll_lock_result(180);
	if (!r) {
		let err = trim(sys(`logread -l 20 2>/dev/null | grep -i "lpac-esim.*FAIL\\|download.*FAILED" | tail -1 | sed 's/.*: //'`));
		if (err) return tg_send(`❌ <b>Download Failed</b>

${html(err)}`, {inline_keyboard: [[{text: "📥 Try Again", callback_data: "menu:download"}], [{text: "🏠 Menu", callback_data: "menu:main"}]]});
		return tg_send("⚠️ <b>Download timeout</b>

Check Profile List for status.", {inline_keyboard: [[{text: "📋 Profile List", callback_data: "menu:profiles"}], [{text: "🏠 Menu", callback_data: "menu:main"}]]});
	}
	if (r.success === false || r.success == "error" || match(r.message || r.error || "", /fail|error|FAILED/i))
		return tg_send(`❌ <b>Download Failed</b>

${html(r.message || r.error || "Unknown error")}`, {inline_keyboard: [[{text: "📥 Try Again", callback_data: "menu:download"}], [{text: "🏠 Menu", callback_data: "menu:main"}]]});
	tg_send("✅ <b>Profile Downloaded</b>

Use Profile List to view and switch.", {inline_keyboard: [[{text: "📋 Profile List", callback_data: "menu:profiles"}, {text: "🔔 Process Notif", callback_data: "act:notifprocess"}], [{text: "🏠 Menu", callback_data: "menu:main"}]]});
}
function do_notif_process() {
	tg_send("⏳");
	let r = lpac_api("notif_process");
	if (r.success || r.message == "success" || r.msg == "success")
		return tg_send("✅ Notifications processed.", {inline_keyboard: [[{text: "📋 Profile List", callback_data: "menu:profiles"}], [{text: "🏠 Menu", callback_data: "menu:main"}]]});
	let locked = poll_lock_result(120);
	if (locked && (locked.success || locked.message == "success"))
		return tg_send("✅ Notifications processed.", {inline_keyboard: [[{text: "📋 Profile List", callback_data: "menu:profiles"}], [{text: "🏠 Menu", callback_data: "menu:main"}]]});
	tg_send("❌ Failed to process notifications.", {inline_keyboard: INLINE_MENU});
}

function do_simslot(slot) {
	if (!config.allow_disruptive) return tg_send("⛔ SIM switch dinonaktifkan.");
	let section = get_modem_section();
	if (!section) return tg_send("❌ Modem section tidak ditemukan.");
	let at_port = modem_get(section, "at_port", "");
	let manufacturer = modem_get(section, "manufacturer", "");
	if (!at_port) return tg_send("❌ AT port modem tidak ditemukan.", {inline_keyboard: INLINE_MENU});
	if (system(`test -e ${sh_quote(at_port)}`) != 0) return tg_send(`❌ AT port tidak tersedia: <code>${html(at_port)}</code>`, {inline_keyboard: INLINE_MENU});
	if (system("test -x /usr/bin/sms_tool_q") != 0) return tg_send("❌ <code>/usr/bin/sms_tool_q</code> tidak tersedia atau tidak executable.", {inline_keyboard: INLINE_MENU});
	tg_send(`⏳ <b>Switching SIM Slot...</b>\nTarget slot: <b>${html(slot)}</b>\n\nInternet mungkin putus sebentar.`);
	let r = "";
	if (match(manufacturer, /[Ff]oxconn/)) r = at_cmd(at_port, `AT^SWITCH_SLOT=${slot}`);
	else if (match(manufacturer, /[Qq]uectel/)) r = at_cmd(at_port, `AT+QUIMSLOT=${slot}`);
	else {
		r = at_cmd(at_port, `AT^SWITCH_SLOT=${slot}`);
		if (!match(r, /OK|SWITCH|SIM/i)) r = at_cmd(at_port, `AT+QUIMSLOT=${slot}`);
	}
	sys_exec("sleep 8");
	let actual = get_current_slot(section);
	if (actual == slot) {
		uci_set(`xmodem.${section}.sim_slot`, slot); sys_exec("uci -q commit xmodem");
		tg_send_retry(`✅ <b>SIM Slot Switched</b>\nCurrent slot: <b>${html(actual)}</b>`, [[{text: "🔄 SIM Switch", callback_data: "menu:simswitch"}, {text: "🏠 Menu", callback_data: "menu:main"}]]);
	} else if (!actual && match(r, /OK/i)) {
		uci_set(`xmodem.${section}.sim_slot`, slot); sys_exec("uci -q commit xmodem");
		tg_send_retry(`⚠️ <b>SIM command sent</b>\nTarget slot: <b>${html(slot)}</b>\nSlot aktual tidak bisa diverifikasi, UCI sudah diupdate.`, [[{text: "🔄 SIM Switch", callback_data: "menu:simswitch"}, {text: "🏠 Menu", callback_data: "menu:main"}]]);
	} else {
		tg_send_retry(`❌ <b>SIM Slot Switch Failed</b>\nTarget: ${html(slot)}\nCurrent: ${html(actual || "unknown")}\nResponse: ${html(r || "-")}`, [[{text: "🔄 SIM Switch", callback_data: "menu:simswitch"}, {text: "🏠 Menu", callback_data: "menu:main"}]]);
	}
}
function do_rename(iccid, name) {
	let r = lpac_api("nickname", {iccid: iccid, nickname: name});
	if (r.success || r.message == "success") tg_send(`✅ <b>Rename Berhasil</b>\nICCID: <code>${html(iccid)}</code>\nNama: <b>${html(name)}</b>`, {inline_keyboard: [[{text: "📋 Profiles", callback_data: "menu:profiles"}]]});
	else tg_send(`❌ <b>Rename Gagal</b>\n${html(r.error || r.msg || "Unknown error")}`, {inline_keyboard: [[{text: "✏️ Retry", callback_data: "menu:rename"}], [{text: "🏠 Menu", callback_data: "menu:main"}]]});
}

function require_confirm(action, arg, text, yes_text) {
	if (!config.require_confirm && action != "download" && action != "simslot") {
		if (action == "switch") return do_switch(arg);
		if (action == "delete") return do_delete(arg);
	}
	set_pending(action, arg);
	tg_send(text, {inline_keyboard: [[{text: yes_text || "✅ Ya", callback_data: "confirm:yes", style: "success"}, {text: "❌ Cancel", callback_data: "cancel", style: "danger"}]]});
}
function handle_callback(cb, data, chat_id, msg_id) {
	chat_id = `${chat_id || ""}`; data = `${data || ""}`;
	if (chat_id != config.chat_id) { log(`Blocked callback chat: ${chat_id} vs config: ${config.chat_id}`); return; }
	log_debug(`Callback ID: ${cb}, Data: ${data}, from: ${chat_id}`);
	if (data == "noop") { tg_answer(cb, "Active profile"); return; }
	tg_answer(cb, "Processing...");
	let p = split(data, ":"); let c = p[0] || "", s = p[1] || "", a = p[2] || "";
	if (data == "cancel") { clear_pending(); update_ui(msg_id, "❌ Dibatalkan.", {inline_keyboard: INLINE_MENU}); return; }
	if (data == "confirm:yes") {
		let pend = get_pending(); clear_pending();
		if (!pend || !pend.action) return update_ui(msg_id, "⚠️ Tidak ada operasi pending.", {inline_keyboard: INLINE_MENU});
		if (pend.action == "switch") return do_switch(pend.arg);
		if (pend.action == "delete") return do_delete(pend.arg);
		if (pend.action == "download") return do_download(pend.arg);
		if (pend.action == "simslot") return do_simslot(pend.arg);
		return update_ui(msg_id, "⚠️ Pending action tidak dikenal.", {inline_keyboard: INLINE_MENU});
	}
	if (c == "menu") {
		if (s == "main") return send_main_menu();
		if (s == "profiles") return ui_profiles(msg_id);
		if (s == "manage") return ui_manage(msg_id);
		if (s == "rename") return ui_rename_menu(msg_id);
		if (s == "download") return ui_download_prompt(msg_id);
		if (s == "notif") return ui_notif(msg_id);
		if (s == "settings") return ui_settings(msg_id);
		if (s == "simswitch") return ui_sim_switch(msg_id);
		if (s == "eid") return ui_eid(msg_id);
	}
	if (c == "act") {
		if (s == "status") return ui_modem(msg_id);
		if (s == "notifprocess" || s == "notif_process") return do_notif_process();
	}
	if (c == "ren") { set_pending("rename", s); return update_ui(msg_id, `✏️ <b>Rename Profile</b>\nICCID: <code>${html(s)}</code>\n\nKirim nama baru 1–64 karakter.`, {inline_keyboard: [[{text: "❌ Cancel", callback_data: "cancel"}]]}); }
	if (c == "simslot") return require_confirm("simslot", s, `⚠️ Switch SIM slot ke <b>${html(s)}</b>?`, "✅ Yes, Switch");
	if (c == "sw") return require_confirm("switch", s, `⚠️ Switch ke <code>${html(s)}</code>?`, "✅ Yes, Switch");
	if (c == "del") return require_confirm("delete", s, profile_delete_confirm_text(s), "🗑 Yes, Delete");
	if (c == "cfg") {
		if (s == "backend" && (a == "qmi" || a == "mbim" || a == "at")) { uci_set("lpac-esim.main.apdu_backend", a); sys_exec("uci -q commit lpac-esim"); return ui_settings(msg_id); }
		if (s == "toggle" && (a == "mbim_proxy" || a == "skip_slot_mapping" || a == "apdu_debug")) { let cur = uci_get(`lpac-esim.main.${a}`, "0"); uci_set(`lpac-esim.main.${a}`, cur == "1" ? "0" : "1"); sys_exec("uci -q commit lpac-esim"); return ui_settings(msg_id); }
	}
	return update_ui(msg_id, "⚠️ Callback tidak dikenal.", {inline_keyboard: INLINE_MENU});
}

function handle_message(chat_id, text) {
	chat_id = `${chat_id || ""}`; text = `${text || ""}`;
	if (chat_id != config.chat_id) { if (text == "/chatid" || text == "/start") tg_send(`Chat ID: <code>${html(chat_id)}</code>`); return; }
	let pend = get_pending();
	if (pend && pend.action == "download" && !pend.arg) {
		if (text == "/cancel" || text == "❌ Cancel") { clear_pending(); return send_main_menu(); }
		if (!is_lpa(text)) return tg_send("⚠️ Format LPA tidak valid. Contoh: <code>LPA:1$server$matchingId</code>", {inline_keyboard: [[{text: "❌ Cancel", callback_data: "cancel"}]]});
		set_pending("download", text);
		return tg_send("📥 Download ini?", {inline_keyboard: [[{text: "✅ Ya", callback_data: "confirm:yes"}, {text: "❌ Cancel", callback_data: "cancel"}]]});
	}
	if (pend && pend.action == "rename" && pend.arg) {
		if (text == "/cancel" || text == "❌ Cancel") { clear_pending(); return send_main_menu(); }
		let name = trim(text);
		if (!name) return tg_send("⚠️ Nama tidak boleh kosong.");
		if (length(name) > 64) return tg_send("⚠️ Nama terlalu panjang. Maksimal 64 karakter.");
		clear_pending(); return do_rename(pend.arg, name);
	}
	if (text == "📱 Info EID" || text == "/eid" || text == "/info") return ui_eid(null);
	if (text == "📋 Profile List" || text == "/profiles" || text == "/profile") return ui_profiles(null);
	if (text == "📥 Download eSIM" || text == "/download") return ui_download_prompt(null);
	if (text == "🔔 Notifications") return ui_notif(null);
	if (text == "📡 Modem Status" || text == "/status") return ui_modem(null);
	if (text == "⚙️ Settings" || text == "/settings") return ui_settings(null);
	if (text == "❓ Help") return ui_help();
	if (text == "/help") return ui_help_short();
	if (text == "🏠 Menu" || text == "Menu" || text == "Menu Utama" || text == "/start" || text == "/menu") return send_main_menu();
	if (text == "/chatid") return tg_send(`Chat ID: <code>${html(chat_id)}</code>`);
	if (text == "/notif") return do_notif_process();
	if (text == "/cancel") { clear_pending(); return send_main_menu(); }
	if (match(text, /^\/download\s+/)) { let lpa = replace(text, /^\/download\s+/, ""); if (!is_lpa(lpa)) return tg_send("⚠️ Format: /download LPA:1$server$matchingId"); return require_confirm("download", lpa, "📥 Download ini?", "✅ Ya"); }
	if (match(text, /^\/(enable|switch)\s+/)) { let iccid = replace(text, /^\/(enable|switch)\s+/, ""); return require_confirm("switch", iccid, `⚠️ Switch ke <code>${html(iccid)}</code>?`, "✅ Ya"); }
	if (text == "/enable" || text == "/switch") return tg_send("⚠️ Format: /enable &lt;ICCID&gt;");
	if (match(text, /^\/delete\s+/)) { let iccid = replace(text, /^\/delete\s+/, ""); return require_confirm("delete", iccid, profile_delete_confirm_text(iccid), "🗑 Ya"); }
	if (text == "/delete") return tg_send("⚠️ Format: /delete &lt;ICCID&gt;");
	return send_main_menu();
}

function process_update(u) {
	if (!u || !exists(u, "update_id")) return;
	if (u.update_id > last_update_id) last_update_id = u.update_id;
	if (exists(u, "callback_query") && u.callback_query) {
		let cb = u.callback_query;
		let msg = cb.message || {};
		let chat = msg.chat ? `${msg.chat.id}` : "";
		let mid = msg.message_id || null;
		handle_callback(cb.id || "", cb.data || "", chat, mid);
		return;
	}
	if (exists(u, "message") && u.message) {
		let chat = u.message.chat ? `${u.message.chat.id}` : "";
		let text = u.message.text || "";
		if (text) handle_message(chat, text);
	}
}

function cleanup() { fs.unlink(PID_FILE); write_status("stopped", 0); }
function main() {
	if (!load_config()) { log("Disabled/Unconfigured"); return; }
	ensure_state_dir();
	let pf = fs.open(PID_FILE, "w"); if (pf) { pf.write(current_pid()); pf.close(); }
	load_offset(); write_status("starting", 0); log("Ucode Bot ready.");
	let fail = 0;
	while (true) {
		let off = last_update_id + 1;
		let r = sys(`curl -s -m 35 ${sh_quote(`${tg_api}/getUpdates?offset=${off}&timeout=25`)}`);
		let data = null; try { data = json(r); } catch (e) {}
		if (!data || !data.ok) { fail++; write_status("error", fail); log_debug(`getUpdates failed: ${r}`); sys_exec("sleep 10"); continue; }
		fail = 0; write_status("ok", 0);
		if (data.result && length(data.result) > 0) {
			for (let i = 0; i < length(data.result); i++) process_update(data.result[i]);
			save_offset();
		}
		if (config.poll_interval > 0) sys_exec(`sleep ${config.poll_interval}`);
	}
}
main();
